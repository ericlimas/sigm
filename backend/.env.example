# Banco de dados
DATABASE_URL="postgresql://sigm:sigm@localhost:5432/sigm_db?schema=public"

# Servidor
PORT=3333
NODE_ENV=development

# JWT
JWT_SECRET="troque-esta-chave-em-producao-access"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="troque-esta-chave-em-producao-refresh"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS (uma ou mais origens separadas por virgula)
CORS_ORIGIN="http://localhost:5173"

# Producao (Supabase): use a connection string do painel Settings > Database
# DATABASE_URL="postgresql://postgres:SENHA@db.xxxxxxxx.supabase.co:5432/postgres?sslmode=require"
# CORS_ORIGIN="https://seu-projeto.vercel.app"
