# Banco de dados
DATABASE_URL="postgresql://sigm:sigm@localhost:5432/sigm_db?schema=public"
# Em producao com pooler (ex: Supabase), DIRECT_URL e usado para migrations
DIRECT_URL="postgresql://sigm:sigm@localhost:5432/sigm_db?schema=public"

# Servidor
PORT=3333
NODE_ENV=development

# JWT
JWT_SECRET="troque-esta-chave-em-producao-access"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="troque-esta-chave-em-producao-refresh"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS (uma ou mais origens separadas por virgula)
CORS_ORIGIN="http://localhost:5173"

# Producao (Supabase, via Connect > ORM > Prisma):
# DATABASE_URL="postgresql://postgres.xxxxxxxx:SENHA@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.xxxxxxxx:SENHA@aws-1-us-east-1.pooler.supabase.com:5432/postgres"
# CORS_ORIGIN="https://seu-projeto.vercel.app"
